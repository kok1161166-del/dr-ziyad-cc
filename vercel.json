{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/clinic run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rootDirectory": "artifacts/clinic",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
